{
	"name": "imgthing",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"preview": "nuxt preview",
		"deploy": "nuxt build && wrangler deploy",
		"postinstall": "nuxt prepare",
		"lint": "biome lint",
		"format": "biome format --write",
		"check": "biome check --write",
		"typecheck": "nuxt typecheck",
		"db:migrate:local": "wrangler d1 migrations apply imgthing --local",
		"db:migrate:remote": "wrangler d1 migrations apply imgthing --remote"
	},
	"dependencies": {
		"@lucide/vue": "^1.23.0",
		"@vueuse/core": "^14.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"nuxt": "^4.4.8",
		"reka-ui": "^2.10.1",
		"shadcn-nuxt": "2.6.2",
		"tailwind-merge": "^3.5.0",
		"vue": "^3.5.33",
		"vue-router": "^5.0.6",
		"vue-sonner": "^2.0.9"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^26.1.0",
		"nitro-cloudflare-dev": "^0.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vue-tsc": "^3.3.5",
		"wrangler": "^4.42.0"
	}
